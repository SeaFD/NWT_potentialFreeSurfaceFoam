FoamFile
{
    version     2.0;
    format      binary;
    arch        "LSB;label=32;scalar=64";
    class       pointVectorField;
    location    "0";
    object      pointDisplacement;
}
// * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * * //

dimensions      [0 1 0 0 0 0 0];

internalField   uniform (0 0 0);

boundaryField
{
    freeSurface
    {
        type            zeroGradient;
    }
    leftWall
    {
        type            timeVaryingUniformFixedValue;
        value           uniform (2.5e-07 0 0);
        file            "waveMakerS03.csv";
        outOfBounds     clamp;
    }
    rightWall
    {
        type            fixedNormalSlip;
        n               (-1 0 0);
    }
    bottomWall
    {
        type            zeroGradient;
    }
    frontAndBack
    {
        type            empty;
    }
}


